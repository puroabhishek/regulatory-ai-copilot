# Python
__pycache__/
*.pyc
*.pyo
*.pyd

# Virtual env
.venv/
venv/

# Environment variables
.env

# macOS
.DS_Store

# Streamlit / local caches
.streamlit/

# Data folders that should stay local
data/*.db
data/processed/
data/regulations/processed/
data/regulations/pdfs/
data/chroma_db/
data/cache/
data/artifacts/
data/generation_runs/
data/control_registry/*
!data/control_registry/.gitkeep

# Reference policies are confidential — do not commit
data/samples/*.md
data/samples/*.docx
data/samples/*.pdf
!data/samples/README.md

# Eval traces can be large and contain sensitive policy text
evals/traces/*
!evals/traces/.gitkeep

# Keep folder structure
!data/.gitkeep

# Logs
logs/
*.log

# Claude Code internal tooling
.claude/